OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini
ENV=local
# OPENAI_BASE_URL=

OCR_ENGINE=tesseract|clova
OCR_ENGINE=tesseract|clova
CLOVA_OCR_INVOKE_URL=your_clova_ocr_invoke_url_here
CLOVA_OCR_SECRET=your_clova_ocr_secret_here

DIARIZATION_ENGINE=none|pyannote
PYANNOTE_HF_TOKEN=your_huggingface_token_here
